{
  "manifest_version": 3,
  "key": "",
  "name": "PigPoints — свинобалы для свиноколеса",
  "version": "1.0.0",
  "description": "Свинобалы для свиноколеса: значки Twitch, балы канала и Google-таблица → ставки в лотах pointauc.com через официальный API.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PigPoints — свинобалы для свиноколеса",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "identity", "alarms"],
  "host_permissions": [
    "https://pointauc.com/*",
    "https://docs.google.com/*",
    "https://script.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*"
  ]
}
